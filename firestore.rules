rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users_v3
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required)
    //   - name: string (required)
    //   - email: string (optional)
    //   - role: string (required, 'parent' | 'child')
    //   - parentId: string (optional, for children)
    //   - photoURL: string (optional)
    //
    // Collection: users_v3/{userId}/contacts
    // Document ID: {contactId}
    // Fields:
    //   - uid: string (required)
    //   - name: string (required)
    //   - approved: bool (required)
    //   - childId: string (required)
    //   - meetAuthorized: bool (optional)
    //
    // Collection: pending_contacts_v3
    // Document ID: {inviteId}
    // Fields:
    //   - targetEmail: string (required)
    //   - fromUid: string (required)
    //   - fromName: string (required)
    //   - fromPhoto: string (optional)
    //   - timestamp: timestamp (required)
    //
    // Collection: chats_v3/{chatId}/messages
    // Document ID: {messageId}
    // Fields:
    //   - senderId: string (required)
    //   - receiverId: string (required)
    //   - text: string (optional)
    //   - mediaUrl: string (optional)
    //   - mediaType: string (required, 'text' | 'image')
    //   - timestamp: timestamp (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isParentOf(childId) {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users_v3/$(childId)).data.parentId == request.auth.uid;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users_v3/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "brunardiass@gmail.com" && request.auth.token.email_verified == true));
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidUser(data) {
      return hasRequiredFields(['uid', 'name', 'role']) &&
             data.uid is string && data.uid.size() > 0 && data.uid.size() < 128 &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.role in ['parent', 'child', 'admin'] &&
             (!('email' in data) || (data.email is string && data.email.size() < 100)) &&
             (!('parentId' in data) || (data.parentId is string && data.parentId.size() < 128)) &&
             (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() < 2000000)) &&
             (!('mood' in data) || (data.mood is string && data.mood.size() < 50)) &&
             (!('moodEmoji' in data) || (data.moodEmoji is string && data.moodEmoji.size() < 20)) &&
             (!('currentStatus' in data) || (data.currentStatus is string && data.currentStatus.size() < 50)) &&
             (!('mascot' in data) || (data.mascot is string && data.mascot.size() < 20)) &&
             (!('favorites' in data) || (data.favorites is map)) &&
             (!('trustedSOSContactEmail' in data) || (data.trustedSOSContactEmail is string && data.trustedSOSContactEmail.size() < 100)) &&
             (!('moodUpdatedAt' in data) || (data.moodUpdatedAt is timestamp || data.moodUpdatedAt == null));
    }

    function isValidContact(data) {
      return hasRequiredFields(['uid', 'name', 'approved', 'childId']) &&
             data.uid is string && data.name is string && data.name.size() < 100 &&
             data.approved is bool && data.childId is string &&
             (!('meetAuthorized' in data) || data.meetAuthorized is bool) &&
             (!('canClearChat' in data) || data.canClearChat is bool) &&
             (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() < 2000000)) &&
             (!('mood' in data) || (data.mood is string && data.mood.size() < 50)) &&
             (!('moodEmoji' in data) || (data.moodEmoji is string && data.moodEmoji.size() < 20)) &&
             (!('currentStatus' in data) || (data.currentStatus is string && data.currentStatus.size() < 50)) &&
             (!('mascot' in data) || (data.mascot is string && data.mascot.size() < 20)) &&
             (!('favorites' in data) || (data.favorites is map)) &&
             (!('lastMessageAt' in data) || (data.lastMessageAt is timestamp || data.lastMessageAt == null)) &&
             (!('hasUnread' in data) || data.hasUnread is bool) &&
             (!('lastMessageText' in data) || (data.lastMessageText is string && data.lastMessageText.size() < 5000));
    }

    function isValidPendingContact(data) {
      return hasRequiredFields(['targetEmail', 'fromUid', 'fromName', 'timestamp']) &&
             data.targetEmail is string && data.fromUid is string &&
             data.fromName is string && data.timestamp is timestamp &&
             (!('fromPhoto' in data) || (data.fromPhoto is string && data.fromPhoto.size() < 2000)) &&
             (!('accepted' in data) || data.accepted is bool);
    }

    function isValidMessage(data) {
      return hasRequiredFields(['senderId', 'receiverId', 'mediaType', 'timestamp']) &&
             data.senderId is string && data.receiverId is string &&
             data.mediaType in ['text', 'image', 'call'] &&
             (!('text' in data) || (data.text is string && data.text.size() < 10000)) &&
             (!('mediaUrl' in data) || (data.mediaUrl is string && data.mediaUrl.size() < 2000)) &&
             (!('meetUrl' in data) || (data.meetUrl is string && data.meetUrl.size() < 2000)) &&
             (data.timestamp is timestamp || data.timestamp == null);
    }

    function isContactSelfUpdate(contactId) {
      return isAuthenticated() && 
             request.auth.uid == contactId && 
             request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['photoURL', 'mood', 'moodEmoji', 'lastMessageAt', 'hasUnread', 'lastMessageText', 'name', 'uid', 'approved', 'childId', 'meetAuthorized']);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /test/connection {
      allow read: if isAuthenticated();
    }

    match /users_v3/{userId} {
      allow read: if isAuthenticated(); 
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && (request.auth.uid == userId);
      allow update: if isAuthenticated() && isValidUser(request.resource.data) && 
                    (isOwner(userId) || isParentOf(userId) || isAdmin()) &&
                    request.resource.data.uid == resource.data.uid &&
                    (request.resource.data.role == resource.data.role || isAdmin());

      match /contacts/{contactId} {
        allow read: if isOwner(userId) || isParentOf(userId) || isAdmin();
        allow create: if isAuthenticated() && 
                      isValidContact(request.resource.data) &&
                      (isOwner(userId) || isParentOf(userId) || isAdmin() || request.auth.uid == contactId);
        allow update: if isAuthenticated() && 
                      isValidContact(request.resource.data) &&
                      (isOwner(userId) || isParentOf(userId) || isAdmin() || request.auth.uid == contactId);
        allow delete: if isOwner(userId) || isParentOf(userId) || isAdmin();
      }
    }

    match /pending_contacts_v3/{inviteId} {
      allow read: if isAuthenticated() && (request.auth.token.email == resource.data.targetEmail || request.auth.uid == resource.data.fromUid || isAdmin());
      allow create: if isAuthenticated() && isValidPendingContact(request.resource.data) && request.resource.data.fromUid == request.auth.uid;
      allow update: if isAuthenticated() && (request.auth.token.email == resource.data.targetEmail) && 
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['accepted']) &&
                    request.resource.data.accepted == true;
      allow delete: if isAuthenticated() && (request.auth.token.email == resource.data.targetEmail || request.auth.uid == resource.data.fromUid || isAdmin());
    }

    match /chats_v3/{chatId} {
      allow read: if isAuthenticated() && (chatId.split('_').hasAny([request.auth.uid]) || isAdmin());
      
      match /messages/{messageId} {
        allow read: if isAuthenticated() && (chatId.split('_').hasAny([request.auth.uid]) || isAdmin());
        allow create: if isAuthenticated() && 
                      isValidMessage(request.resource.data) &&
                      (request.resource.data.senderId == request.auth.uid) &&
                      (chatId.split('_').hasAny([request.auth.uid]));
        allow delete: if isAuthenticated() && (chatId.split('_').hasAny([request.auth.uid]) || isAdmin());
      }
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
